{
  "name": "@mskyurina/agent-workspace",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "agent-workspace": ".agents/skills/orchestrate-agent-workspaces/scripts/cli.ts"
  },
  "scripts": {
    "agent-workspace": "bun .agents/skills/orchestrate-agent-workspaces/scripts/cli.ts",
    "test": "bun test --timeout 20000",
    "test:coverage": "bun test --coverage --coverage-reporter=text --timeout 30000",
    "typecheck": "tsc --noEmit",
    "test:package": "bun scripts/test-package.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "typescript": "^5.9.3"
  },
  "description": "Transactional Git worktrees for isolated coding-agent changes and serialized integration.",
  "files": [
    ".agents/skills/orchestrate-agent-workspaces/**",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hirate99/agent-workspace.git"
  },
  "homepage": "https://github.com/Hirate99/agent-workspace#readme",
  "bugs": {
    "url": "https://github.com/Hirate99/agent-workspace/issues"
  },
  "keywords": [
    "agent",
    "git",
    "worktree",
    "codex",
    "cli"
  ],
  "engines": {
    "bun": ">=1.3.0",
    "git": ">=2.31.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
